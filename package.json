{
  "name": "maintainer-kit",
  "version": "0.3.1",
  "private": true,
  "description": "Turn GitHub Issues and Pull Requests into actionable Decision Briefs.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "files": [
    "action.yml",
    "dist",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run && node --test tests/*.node-test.mjs",
    "lint": "eslint .",
    "format": "prettier --check .",
    "bundle": "ncc build src/index.ts -o dist --target es2020",
    "build": "pnpm typecheck && pnpm bundle"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "openai": "^5.8.2",
    "yaml": "^2.8.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^20.19.1",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^9.29.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
